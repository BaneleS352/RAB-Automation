# ===========================================
# RAB Automation Service - Environment Config
# ===========================================

APP_NAME=rab-automation
APP_ENV=local
LOG_LEVEL=INFO

# Required: URL configured in Jira for webhook delivery
JIRA_WEBHOOK_URL=http://localhost:8000/webhooks/jira

# Jira API
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=automation.user@company.com
JIRA_API_TOKEN=replace_me

# Jira project
JIRA_PROJECT_KEY=

# Jira custom field IDs (map logical field names to Jira custom field IDs)
JIRA_FIELD_PR_LINK=
JIRA_FIELD_PIPELINE_LINK=
JIRA_FIELD_RAB_APPROVER=
JIRA_FIELD_DEVELOPER=
JIRA_FIELD_TEAM_LEAD=
JIRA_FIELD_PM=
JIRA_FIELD_QA=
JIRA_FIELD_ENVIRONMENT=
JIRA_FIELD_ROLLBACK_DETAILS=
JIRA_FIELD_DATE_TIME=

# Jira workflow transition IDs
JIRA_TRANSITION_VALIDATE=
JIRA_TRANSITION_REQUEST_APPROVAL=
JIRA_TRANSITION_APPROVE=
JIRA_TRANSITION_REJECT=

# Azure DevOps (for PR + pipeline verification)
AZURE_DEVOPS_ORG=
AZURE_DEVOPS_PROJECT=
AZURE_DEVOPS_REPO_ID=
AZURE_DEVOPS_PAT=replace_me

# Teams / Azure Bot (for notifications + approvals)
TEAMS_TENANT_ID=
TEAMS_BOT_APP_ID=
TEAMS_BOT_CLIENT_SECRET=
TEAMS_CHANNEL_ID=

# SharePoint (for RAB audit entries)
SHAREPOINT_SITE_ID=replace_me
SHAREPOINT_LIST_ID=replace_me
